/* 全局样式 */
page {
  background-color: #0f0f1a;
  color: #e0e0e0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
}

/* 颜色主题 */
:root {
  --bg-primary: #0f0f1a;
  --bg-card: #1a1a2e;
  --bg-card-hover: #222240;
  --text-primary: #ffffff;
  --text-secondary: #a0a0b8;
  --text-muted: #666680;
  --up-color: #e63946;
  --down-color: #2ecc71;
  --warning: #f39c12;
  --accent: #457b9d;
  --border: #2a2a40;
}

/* 涨跌颜色 */
.up { color: #e63946; }
.down { color: #2ecc71; }
.flat { color: #a0a0b8; }
.bg-up { background-color: rgba(230, 57, 70, 0.15); }
.bg-down { background-color: rgba(46, 204, 113, 0.15); }

/* 通用卡片 */
.card {
  background-color: #1a1a2e;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx;
}

/* 加载状态 */
.loading-center {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

/* 错误提示 */
.error-text {
  color: #e63946;
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
}
